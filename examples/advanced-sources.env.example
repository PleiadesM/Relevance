# Relevance — local development env template.
# Copy to .env (gitignored), fill in, then load with:  set -a; source .env; set +a
# In production these live in GitHub → Settings → Secrets and variables → Actions.

# ---- Secrets (never commit real values) ------------------------------------

# Master passphrase for all encryption. Also your browser login. Use >= 4 random words.
NEWSDASH_PASSPHRASE=

# Optional: makes the OpenAlex fetcher reliable (keyless requests are best-effort).
OPENALEX_API_KEY=

# Optional: radar-compatible OPML, decoded to feeds/follow.opml at build time.
FOLLOW_OPML_B64=

# ---- Variables (tuning + kill switches) -------------------------------------

# Joins the CrossRef/OpenAlex polite pools (recommended; any email you own).
CONTACT_MAILTO=

# Cap on feeds pulled from an OPML file (default 10).
#RSS_MAX_FEEDS=10
