{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://newsdash.invalid/schema/site.schema.json",
  "title": "Relevance site config",
  "type": "object",
  "required": ["schema_version", "title", "visibility", "languages", "default_language", "theme", "timezone"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "const": 1 },
    "title": { "type": "string", "minLength": 1, "maxLength": 120 },
    "subtitle": { "type": "string", "maxLength": 200 },
    "visibility": { "enum": ["public", "private"] },
    "languages": {
      "type": "array",
      "items": { "enum": ["en", "zh"] },
      "minItems": 1,
      "uniqueItems": true
    },
    "default_language": { "enum": ["en", "zh"] },
    "theme": { "enum": ["the-type", "nyt", "bear"] },
    "timezone": { "type": "string", "minLength": 1 },
    "windows": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "news_hours": { "type": "integer", "minimum": 1, "maximum": 168 },
        "papers_days": { "type": "integer", "minimum": 1, "maximum": 60 },
        "archive_days": { "type": "integer", "minimum": 1, "maximum": 90 }
      }
    }
  }
}
