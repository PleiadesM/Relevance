{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://newsdash.invalid/schema/sources.schema.json",
  "title": "Personal Newsdash sources config",
  "type": "object",
  "required": ["schema_version", "presets", "sources"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "const": 1 },
    "presets": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9-]{2,64}$" },
      "uniqueItems": true
    },
    "interests": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "keywords": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "boost": { "type": "number", "minimum": 0, "maximum": 0.5 }
      }
    },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/source" }
    },
    "tag_rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/tag_rule" }
    }
  },
  "$defs": {
    "tag_rule": {
      "type": "object",
      "required": ["tag", "any"],
      "additionalProperties": false,
      "properties": {
        "tag": { "type": "string", "pattern": "^[a-z0-9-]{2,32}$" },
        "any": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "section": { "type": "string", "pattern": "^[a-z0-9_-]{2,32}$" }
      }
    },
    "source": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_]{2,64}$" },
        "category": { "enum": ["open", "private", "optional"] },
        "type": {
          "enum": ["rss", "opml", "feed-json", "static-page", "arxiv", "openalex",
                   "crossref", "semanticscholar", "ics", "canvas"]
        },
        "section": { "type": "string", "pattern": "^[a-z0-9_-]{2,32}$" },
        "name": { "type": "string", "minLength": 1, "maxLength": 120 },
        "url": { "type": "string", "pattern": "^https?://" },
        "path": { "type": "string", "minLength": 1 },
        "query": { "type": "string", "minLength": 1 },
        "filter": { "type": "string", "minLength": 1 },
        "lang": { "enum": ["zh", "en", "auto"] },
        "keywords": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "issn": { "type": "array", "items": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{3}[0-9Xx]$" } },
        "max_results": { "type": "integer", "minimum": 1, "maximum": 200 },
        "weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "enabled": { "anyOf": [{ "type": "boolean" }, { "const": "auto" }] },
        "secret_ref": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]{1,63}$" },
          "minItems": 1
        },
        "_comment": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "category": { "const": "private" } }, "required": ["category"] },
          "then": { "allOf": [
            { "not": { "required": ["url"] } },
            { "not": { "required": ["path"] } }
          ] }
        }
      ]
    }
  }
}
